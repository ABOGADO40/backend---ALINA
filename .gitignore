# Dependencies
node_modules
.pnp
.pnp.js

# Build outputs
dist
dist-ssr
build
*.local

# Environment files
# ============================================================================
# IMPORTANTE: El archivo .env contiene credenciales locales
# NUNCA subir a repositorios publicos
# Railway usa sus propias variables de entorno (no depende de este archivo)
# ============================================================================
.env
.env.local
.env.development.local
.env.test.local
.env.production.local

# Logs
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# Editor directories and files
.vscode/*
!.vscode/extensions.json
.idea
.DS_Store
*.suo
*.ntvs*
*.njsproj
*.sln
*.sw?

# Testing
coverage
*.lcov

# Misc
*.pem
.cache

# ============================================================================
# UPLOADS - Archivos de evidencia (se generan dinámicamente)
# Mantener estructura base, ignorar contenido
# ============================================================================
uploads/bitcopy/*
!uploads/bitcopy/.gitkeep

uploads/certificates/*
!uploads/certificates/.gitkeep

uploads/derived/*
!uploads/derived/.gitkeep

uploads/eventlog/*
!uploads/eventlog/.gitkeep

uploads/exports/*
!uploads/exports/.gitkeep

uploads/original/*
!uploads/original/.gitkeep

uploads/reports/*
!uploads/reports/.gitkeep

uploads/sealed/*
!uploads/sealed/.gitkeep

uploads/temp/*
!uploads/temp/.gitkeep

# ============================================================================
# TEMP - Archivos temporales de desarrollo
# Mantener estructura base, ignorar contenido
# ============================================================================
temp/db_compare/*
!temp/db_compare/.gitkeep

temp/scripts/*
!temp/scripts/.gitkeep

__tests__